# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=generate-a-long-random-secret-key-here

# Google OAuth Credentials
GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# PayPal Configuration
PAYPAL_CLIENT_ID=your-paypal-sandbox-client-id-here
PAYPAL_SECRET=your-paypal-sandbox-client-secret-here

# UPI Configuration
UPI_ID=your-upi-id-at-bank-here@upi
LINKEDIN_URL=https://www.linkedin.com/in/your-profile-here

# SMTP & Contact Email Configurations
CONTACT_EMAIL=your-receiver-email@example.com
SMTP_SERVER=smtp.gmail.com
SMTP_USERNAME=your-smtp-username@gmail.com
SMTP_PASSWORD=your-smtp-password-app-key-here
SMTP_PORT=587


# Security & Admin Configurations
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=bcrypt-password-hash-here

# Data Retention Policy
DATA_RETENTION_HOURS=24
